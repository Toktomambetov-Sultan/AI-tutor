# PostgreSQL
DATABASE_URL=postgresql+asyncpg://ai_teacher:ai_teacher_pass@db:5432/ai_teacher
POSTGRES_USER=ai_teacher
POSTGRES_PASSWORD=ai_teacher_pass
POSTGRES_DB=ai_teacher

# Redis
REDIS_URL=redis://redis:6379/0

# Auth
SECRET_KEY=change-me-to-a-real-secret-key
SESSION_TTL_SECONDS=86400

# File uploads
UPLOAD_DIR=/app/uploads

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Environment
ENVIRONMENT=development

# Seed Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_on_first_login
ADMIN_FULL_NAME=Platform Admin

# Hard Delete
HARD_DELETE_RETENTION_DAYS=90
